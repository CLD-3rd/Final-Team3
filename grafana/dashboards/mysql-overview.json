{
  "uid": "matchfit-mysql",
  "title": "MatchFit MySQL Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "matchfit",
    "mysql"
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Queries per second",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(mysql_global_status_questions[1m])"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Avg statement latency (seconds)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(mysql_perf_schema_events_statements_seconds_total[1m]) / rate(mysql_perf_schema_events_statements_total[1m])"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Rows examined per second",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(mysql_perf_schema_events_statements_rows_examined_total[1m])"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Rows sent per second",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(mysql_perf_schema_events_statements_rows_sent_total[1m])"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Thread running",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mysql_global_status_threads_running"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "InnoDB buffer pool reads/sec",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(mysql_global_status_innodb_buffer_pool_reads[1m])"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      }
    }
  ]
}
