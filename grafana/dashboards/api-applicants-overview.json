{
  "uid": "matchfit-api-applicants",
  "title": "MatchFit Applicants API",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "tags": [
    "matchfit",
    "api"
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GET /{postId}/applicants - Requests per second",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{method=\"GET\",uri=\"/api/posts/{postId}/applicants\"}[1m]))"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GET /{postId}/applicants - Avg latency (seconds)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_sum{method=\"GET\",uri=\"/api/posts/{postId}/applicants\"}[1m])) / sum(rate(http_server_requests_seconds_count{method=\"GET\",uri=\"/api/posts/{postId}/applicants\"}[1m]))"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      }
    }
  ]
}
